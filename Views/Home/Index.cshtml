@model IEnumerable<PracticeApi.Models.User>

@{
    Layout = null;
}
<div>
    <h1>hello @(Context.Session.GetString("username") ?? "guest")</h1>
    <a href="/Auth/Logout">Logout</a>

    <hr>

    <form method="post" action="/Home/Create" required>
        username:<input type="text" name="Username" required /><br /><br />
        password:<input type="password" name="Password" required /><br /><br />
        <button type="submit">them </button>
    </form>

    <hr>

    @foreach (var u in Model)
    {
        <tr>
            <td>@u.Id</td>
            <td>@u.Username</td>
            <td>@u.Password</td>
            <td>
                <a href="/Home/Edit/@u.Id">sua</a>
                <a href="/Home/Delete/@u.Id">xoa</a>
                <br /><br />
            </td>
        </tr>
    }

    <hr>




</div>